CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PORT=5000

# MongoDB Atlas Free-Tier connection string format
# MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.xxxx.mongodb.net/<db_name>?retryWrites=true&w=majority
MONGO_URI=

# A long, complex random string for signing JWT tokens
JWT_SECRET=

# Frontend URL used to build shareable link URLs returned to clients
FRONTEND_URL=http://localhost:3000
